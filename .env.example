# Copy this file to .env and fill in your values
# cp .env.example .env

# --- System ---
MAX_CORES=6
MAX_WORKERS=8

# --- Infrastructure ---
OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=F16_Manual_Collection
# Leave blank for local Qdrant (no auth required)
QDRANT_API_KEY=

# --- Models ---
EMBED_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768
GEN_MODEL=llama3.1:8b-instruct-q4_K_S
RERANKER_MODEL=Alibaba-NLP/gte-reranker-modernbert-base
EVAL_GROUND_TRUTH_MODEL=llama3.1:8b-instruct-q4_K_S
TOKENIZER_MODEL=cl100k_base
HF_CACHE_DIR=./models_cache

# --- Processing ---
EMBED_BATCH_SIZE=16
BATCH_SIZE=16
MAX_RESPONSE_TOKENS=512

# --- Chunking Strategy ---
MAX_CHUNK_TOKENS=1000
MIN_CHUNK_TOKENS=20
CHUNK_OVERLAP_TOKENS=100

# --- Retrieval ---
TOP_K_INITIAL=8
TOP_K_FINAL=2

# --- Evaluation ---
EVAL_QUERIES=100
EVAL_DATASET_PATH=./dataset/eval_dataset.csv

# --- Paths ---
DATA_DIR=./data
OUTPUT_DIR=./output
EVAL_DIR=./dataset

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns
# MLFLOW_ARTIFACT_LOCATION=   # leave blank for local default
PIPELINE_VERSION=1.0.0
ENV=dev
